# .env.example
#
# Placeholder names for every secret the jobs read. Real values live only as GitHub Actions secrets
# and are never committed - these are just identifiers, safe to keep in the repo. Copy this to .env
# (which is gitignored) to run a script locally, and fill in the ones that script needs. Each script
# only reads the handful it uses; see scripts/README.md and each workflow's env block.

# --- Supabase (nearly every job) -------------------------------------------------
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=      # bypasses RLS; used by the database-backed jobs
SUPABASE_KEY=                   # job-scraper
SUPABASE_ANON_KEY=              # job-scraper

# --- Discord webhooks (one per channel) ------------------------------------------
DISCORD_WEBHOOK_CODING=         # daily-coding-summary
DISCORD_WEBHOOK_ROUTINE=        # routine
DISCORD_WEBHOOK_STREAKS=        # streak-reminder
DISCORD_WEBHOOK_VAULT=          # vault-expiry-check
DISCORD_WEBHOOK_REMINDERS=      # medication-reminders, reminders
DISCORD_WEBHOOK_URL=            # job-scraper run summary
DISCORD_WEBHOOK_ERRORS=         # job-scraper failure alert (the #errors channel)
DISCORD_WEBHOOK_POSTS=          # daily-analytics: Posts summary
DISCORD_WEBHOOK_FITNESS=        # daily-analytics: Fitness summary
DISCORD_WEBHOOK_APPLICATIONS=   # daily-analytics: Applications summary
DISCORD_WEBHOOK_MUSIC=          # daily-analytics: Music summary (optional; skipped if unset)

# --- Monitoring (all jobs) -------------------------------------------------------
HEALTHCHECK_PING_KEY=           # Healthchecks.io ping key; each job pings hc-ping.com/<key>/<slug>
                                # on start, success and fail. No key set = pings are a no-op.

# --- WakaTime --------------------------------------------------------------------
WAKATIME_API_KEY=

# --- Spotify (spotify-history) ---------------------------------------------------
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# --- Email and SMS (medication-reminders, reminders) -----------------------------
RESEND_API_KEY=
REMINDER_FROM_EMAIL=            # defaults to a hello@ address if unset
TWILIO_ACCOUNT_SID=             # SMS only
TWILIO_AUTH_TOKEN=              # SMS only
TWILIO_FROM_NUMBER=             # SMS only

# --- AI providers (job-scraper, recategorise; at least one) ----------------------
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=
GH_MODELS_TOKEN=

# --- Job-board APIs (job-scraper) ------------------------------------------------
REED_API_KEY=
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=

# --- Behaviour flags (optional; the workflows set these, code has sensible defaults) ---
# Not secrets - you do not need to provision these. They tune behaviour and each has a default.
# SCRAPER_MODE=all              # api | browser | all  (the workflow runs api and browser in parallel)
# SCRAPER_BUDGET_MIN=110        # per-job wall-clock budget in minutes
# SCRAPER_AI_BUDGET=150         # AI extraction call budget
# SCRAPER_AI_TEST=              # non-empty runs a single AI self-test and exits
# RECATEGORISE_DRY_RUN=         # non-empty previews the re-categorisation without writing
# FORCE=                        # 1 bypasses the UK-hour gate and idempotency (manual test runs)
